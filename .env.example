# ══════════════════════════════════════════════════════════════
#  SSO Auth — Configuration
#  cp .env.example .env  puis adapter les valeurs
# ══════════════════════════════════════════════════════════════

APP_NAME="SSO Auth"
ENVIRONMENT=development
DEBUG=true
BASE_URL=http://localhost:8000

# Générer : python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REMPLACER_PAR_CLE_ALEATOIRE_GENEREE

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Adapter user/password selon votre PostgreSQL local
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sso_auth

# Redis facultatif — le service fonctionne sans (rate limiting désactivé)
REDIS_URL=redis://localhost:6379/0

CORS_ORIGINS=http://localhost:3000,http://localhost:5173

MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MIN=15

TOTP_ISSUER="SSO Auth"

# Premier admin créé automatiquement au démarrage
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=AdminPass1!

# OAuth2 Google — https://console.cloud.google.com/apis/credentials
# Redirection autorisée : http://localhost:8000/api/v1/oauth2/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth2 GitHub — https://github.com/settings/applications/new
# Callback URL : http://localhost:8000/api/v1/oauth2/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
